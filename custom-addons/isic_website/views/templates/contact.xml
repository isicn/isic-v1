<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ========================================================
         ISIC Website — Page: Contact
    ========================================================= -->
    <template id="page_contact" name="ISIC: Contact">
        <t t-call="website.layout">
            <t t-set="additional_title">ISIC - Contact</t>

            <div id="wrap">

                <!-- Banner -->
                <section class="isic-page-banner">
                    <div class="isic-container">
                        <h1 class="isic-page-banner__title">Contact</h1>
                        <div class="isic-page-banner__breadcrumb">
                            <a href="/">Accueil</a> <span>/</span> Contact
                        </div>
                    </div>
                </section>

                <!-- ======== SUCCESS MESSAGE ======== -->
                <t t-if="success">
                    <section class="isic-section">
                        <div class="isic-container">
                            <div class="isic-www-contact-success">
                                <div class="isic-www-contact-success__icon">
                                    <i class="fa fa-check-circle" title="Succès"/>
                                </div>
                                <h2 class="isic-www-contact-success__title">Message envoyé avec succès</h2>
                                <p class="isic-www-contact-success__text">
                                    Merci de nous avoir contactés. Nous vous répondrons dans les meilleurs délais.
                                </p>
                                <a href="/" class="isic-www-btn isic-www-btn--primary mt-3">
                                    <i class="fa fa-home" title="Accueil"/> Retour à l'accueil
                                </a>
                            </div>
                        </div>
                    </section>
                </t>

                <!-- ======== CONTACT FORM + INFO ======== -->
                <t t-if="not success">

                    <section class="isic-section isic-www-reveal">
                        <div class="isic-container">
                            <div class="isic-www-contact-layout">

                                <!-- Left: Form -->
                                <div class="isic-www-contact-form-wrap">
                                    <h2 style="font-size:1.5rem;font-weight:700;color:#1b3a5c;margin-bottom:0.5rem;">
                                        Envoyez-nous un message
                                    </h2>
                                    <p style="color:#6b7b8d;margin-bottom:2rem;">
                                        Remplissez le formulaire ci-dessous et nous vous répondrons rapidement.
                                    </p>

                                    <form action="/contact/submit" method="POST" class="isic-www-form">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                        <div class="isic-www-form__group">
                                            <label class="isic-www-form__label" for="contact_name">
                                                Nom complet <span class="text-danger">*</span>
                                            </label>
                                            <input type="text" id="contact_name" name="name"
                                                   class="isic-www-form__input"
                                                   t-att-class="'isic-www-form__input' + (' isic-www-form__input--error' if error.get('name') else '')"
                                                   t-att-value="name if name else ''"
                                                   placeholder="Votre nom complet"/>
                                            <t t-if="error.get('name')">
                                                <div class="isic-www-form__error" t-out="error['name']"/>
                                            </t>
                                        </div>

                                        <div class="isic-www-form__group">
                                            <label class="isic-www-form__label" for="contact_email">
                                                Email <span class="text-danger">*</span>
                                            </label>
                                            <input type="email" id="contact_email" name="email"
                                                   t-att-class="'isic-www-form__input' + (' isic-www-form__input--error' if error.get('email') else '')"
                                                   t-att-value="email if email else ''"
                                                   placeholder="votre.email@exemple.com"/>
                                            <t t-if="error.get('email')">
                                                <div class="isic-www-form__error" t-out="error['email']"/>
                                            </t>
                                        </div>

                                        <div class="isic-www-form__group">
                                            <label class="isic-www-form__label" for="contact_subject">
                                                Objet
                                            </label>
                                            <input type="text" id="contact_subject" name="subject"
                                                   class="isic-www-form__input"
                                                   t-att-value="subject if subject else ''"
                                                   placeholder="Objet de votre message"/>
                                        </div>

                                        <div class="isic-www-form__group">
                                            <label class="isic-www-form__label" for="contact_message">
                                                Message <span class="text-danger">*</span>
                                            </label>
                                            <textarea id="contact_message" name="message"
                                                      t-att-class="'isic-www-form__textarea' + (' isic-www-form__input--error' if error.get('message') else '')"
                                                      rows="6"
                                                      placeholder="Votre message..."><t t-if="message" t-out="message"/></textarea>
                                            <t t-if="error.get('message')">
                                                <div class="isic-www-form__error" t-out="error['message']"/>
                                            </t>
                                        </div>

                                        <button type="submit" class="isic-www-btn isic-www-btn--primary isic-www-btn--lg w-100">
                                            <i class="fa fa-paper-plane" title="Envoyer"/> Envoyer le message
                                        </button>
                                    </form>
                                </div>


                            </div>
                        </div>
                    </section>

                    <!-- ======== MAP ======== -->
                    <section class="isic-section isic-section--light isic-www-reveal">
                        <div class="isic-container">
                            <div class="isic-section__header">
                                <h2 class="isic-section__title">Nous Trouver</h2>
                                <p class="isic-section__subtitle">
                                    Avenue Allal El Fassi, Madinat Al Irfane, Rabat
                                </p>
                            </div>
                            <div class="isic-www-contact-map">
                                <iframe
                                    src="https://maps.google.com/maps?q=Higher+Institute+of+Information+and+Communication,+Av.+Allal+Al+Fassi,+Rabat+10100,+Morocco&amp;t=&amp;z=17&amp;ie=UTF8&amp;iwloc=&amp;output=embed"
                                    width="100%" height="450" style="border:0;border-radius:12px;"
                                    allowfullscreen="" loading="lazy"
                                    referrerpolicy="no-referrer-when-downgrade"
                                    title="Carte ISIC Rabat">
                                </iframe>
                            </div>
                        </div>
                    </section>

                </t>

            </div>
        </t>
    </template>

</odoo>
