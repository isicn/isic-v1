<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ========================================================
         ISIC Website — Layout Overrides
    ========================================================= -->

    <!-- Hide the default Odoo copyright bar below the footer -->
    <template id="isic_no_copyright" inherit_id="website.layout" name="ISIC: Hide Default Copyright" priority="99">
        <xpath expr="//div[hasclass('o_footer_copyright')]" position="before">
            <t t-set="no_copyright" t-value="True"/>
        </xpath>
    </template>

    <!-- Deactivate the header CTA button ("Contactez-nous") -->
    <record id="website.header_call_to_action" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <!-- Deactivate the header phone number text element -->
    <record id="website.header_text_element" model="ir.ui.view">
        <field name="active" eval="False"/>
    </record>

    <!-- Replace the default footer with ISIC 4-column footer -->
    <template id="isic_footer" inherit_id="website.layout" name="ISIC Footer" priority="99">
        <xpath expr="//div[@id='footer']" position="replace">
            <div id="footer" t-if="not no_footer">
                <footer class="isic-www-footer">
                    <div class="isic-container">
                        <div class="row py-5">

                            <!-- Col 1: À propos -->
                            <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                                <h6 class="isic-www-footer__title">ISIC</h6>
                                <p class="isic-www-footer__text">
                                    Institut Supérieur de l'Information et de la Communication.
                                    Former les leaders de l'information et de la communication depuis 1969.
                                </p>
                                <div class="isic-www-social">
                                    <a href="https://www.facebook.com/isic.officiel" target="_blank"
                                       rel="noopener" class="isic-www-social__link" title="Facebook">
                                        <i class="fa fa-facebook" title="Facebook"/>
                                    </a>
                                    <a href="https://www.youtube.com/@isicrabat8096" target="_blank"
                                       rel="noopener" class="isic-www-social__link" title="YouTube">
                                        <i class="fa fa-youtube-play" title="YouTube"/>
                                    </a>
                                </div>
                            </div>

                            <!-- Col 2: Liens rapides -->
                            <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                                <h6 class="isic-www-footer__title">Liens rapides</h6>
                                <ul class="isic-www-footer__links">
                                    <li><a href="/institut">L'Institut</a></li>
                                    <li><a href="/formations">Formations</a></li>
                                    <li><a href="/vie-etudiante">Vie Étudiante</a></li>
                                    <li><a href="/recherche">Recherche</a></li>
                                    <li><a href="/blog">Actualités</a></li>
                                    <li><a href="/contact">Contact</a></li>
                                </ul>
                            </div>

                            <!-- Col 3: Formations -->
                            <div class="col-lg-3 col-md-6 mb-4 mb-lg-0">
                                <h6 class="isic-www-footer__title">Formations</h6>
                                <ul class="isic-www-footer__links">
                                    <li><a href="/formations#licence">Licence Information et Communication</a></li>
                                    <li><a href="/formations#masters">Master IPROCAN</a></li>
                                    <li><a href="/formations#masters">Master Communication Politique</a></li>
                                    <li><a href="/formations#masters">Master Journalisme Sportif</a></li>
                                    <li><a href="/formations#fc">Formation Continue</a></li>
                                </ul>
                            </div>

                            <!-- Col 4: Contact -->
                            <div class="col-lg-3 col-md-6">
                                <h6 class="isic-www-footer__title">Contact</h6>
                                <ul class="isic-www-footer__links isic-www-footer__links--contact">
                                    <li>
                                        <i class="fa fa-map-marker me-2" title="Adresse"/>
                                        Avenue Allal El Fassi, Madinat Al Irfane, Rabat
                                    </li>
                                    <li>
                                        <i class="fa fa-phone me-2" title="Téléphone"/>
                                        (+212) 0537 77 33 40
                                    </li>
                                    <li>
                                        <i class="fa fa-envelope me-2" title="Email"/>
                                        <a href="mailto:contact@isic.ac.ma">contact@isic.ac.ma</a>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <!-- Bottom bar -->
                        <div class="isic-www-footer__bottom">
                            <span>2026 ISIC — Université Mohammed V, Rabat. Tous droits réservés.</span>
                        </div>
                    </div>
                </footer>
            </div>
        </xpath>
    </template>

</odoo>
