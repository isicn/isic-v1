<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <!-- ============================================================ -->
    <!-- Form: add GED fields + workflow buttons                      -->
    <!-- ============================================================ -->
    <record id="view_dms_file_form_ged" model="ir.ui.view">
        <field name="name">dms.file.form.inherit.isic_ged</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_form" />
        <field name="arch" type="xml">
            <!-- Make base DMS fields readonly when validated/archived -->
            <xpath expr="//div[@class='oe_title']//field[@name='name']" position="attributes">
                <attribute name="readonly">ged_state != 'draft'</attribute>
            </xpath>
            <xpath expr="//group[@name='content']//field[@name='content']" position="attributes">
                <attribute name="readonly">ged_state != 'draft'</attribute>
            </xpath>
            <xpath expr="//group[@name='settings']//field[@name='directory_id']" position="attributes">
                <attribute name="readonly">ged_state != 'draft'</attribute>
            </xpath>
            <xpath expr="//group[@name='settings']//field[@name='category_id']" position="attributes">
                <attribute name="readonly">ged_state != 'draft'</attribute>
            </xpath>
            <xpath expr="//group[@name='settings']//field[@name='tag_ids']" position="attributes">
                <attribute name="readonly">ged_state != 'draft'</attribute>
            </xpath>
            <!-- Workflow buttons in header -->
            <xpath expr="//header" position="inside">
                <button
                    name="action_validate"
                    string="Valider"
                    type="object"
                    class="btn-primary"
                    invisible="ged_state != 'draft'"
                    groups="isic_base.group_isic_scolarite"
                />
                <button
                    name="action_archive_ged"
                    string="Classer"
                    type="object"
                    class="btn-primary"
                    invisible="ged_state != 'validated'"
                    groups="isic_base.group_isic_scolarite"
                />
                <button
                    name="action_reset_draft"
                    string="Remettre en brouillon"
                    type="object"
                    invisible="ged_state == 'draft'"
                    groups="isic_base.group_isic_direction"
                />
                <field
                    name="ged_state"
                    widget="statusbar"
                    statusbar_visible="draft,validated,archived"
                />
            </xpath>
            <!-- GED tabs in notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Métadonnées GED" name="page_ged_metadata">
                    <group>
                        <group>
                            <field name="document_type_id" readonly="ged_state != 'draft'" />
                            <field name="reference" readonly="ged_state != 'draft'" />
                            <field name="partner_id" />
                            <field name="auto_classified" invisible="not auto_classified" />
                        </group>
                        <group>
                            <field name="date_document" readonly="ged_state != 'draft'" />
                            <field name="annee_academique_id" readonly="ged_state != 'draft'" />
                        </group>
                    </group>
                </page>
                <page string="Validation" name="page_ged_validation" invisible="ged_state == 'draft'">
                    <group>
                        <group>
                            <field name="valideur_id" />
                            <field name="date_validation" />
                        </group>
                    </group>
                </page>
                <page string="Versions" name="page_versions">
                    <field name="version_ids" mode="list" readonly="1">
                        <list create="false" edit="false" delete="false">
                            <field name="version_number" />
                            <field name="name" />
                            <field name="author_id" />
                            <field name="date" />
                            <field name="human_size" />
                            <field name="comment" />
                            <button name="action_restore"
                                string="Restaurer"
                                type="object"
                                icon="fa-undo"
                                groups="isic_base.group_isic_scolarite"
                                confirm="Restaurer cette version ? Le contenu actuel sera sauvegardé comme nouvelle version."
                            />
                        </list>
                    </field>
                    <group>
                        <field name="version_count" />
                        <field name="current_version" />
                    </group>
                </page>
                <page string="Aperçu" name="page_preview" invisible="preview_type == 'none'">
                    <field name="preview_type" invisible="1" />
                    <div class="o_isic_preview_container">
                        <field name="preview_type" widget="preview_embed" nolabel="1" />
                        <div class="mt-2">
                            <button name="action_preview"
                                string="Ouvrir dans un nouvel onglet"
                                type="object"
                                class="btn btn-outline-secondary btn-sm"
                                icon="fa-external-link"
                            />
                        </div>
                    </div>
                </page>
                <page string="Indexation" name="page_fulltext" groups="isic_base.group_isic_direction">
                    <group>
                        <field name="fulltext_indexed" />
                        <field name="fulltext_error" invisible="not fulltext_error" />
                    </group>
                    <group>
                        <field name="fulltext_content" readonly="1" />
                    </group>
                    <div>
                        <button name="action_reindex_fulltext"
                            string="Réindexer"
                            type="object"
                            class="btn btn-outline-secondary"
                            groups="isic_base.group_isic_direction"
                        />
                    </div>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- List: add GED columns                                        -->
    <!-- ============================================================ -->
    <record id="view_dms_file_list_ged" model="ir.ui.view">
        <field name="name">dms.file.list.inherit.isic_ged</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mimetype']" position="after">
                <field name="document_type_id" optional="show" />
                <field name="reference" optional="show" />
                <field name="partner_id" optional="hide" />
                <field name="date_document" optional="hide" />
                <field name="ged_state" widget="badge"
                    decoration-info="ged_state == 'draft'"
                    decoration-success="ged_state == 'validated'"
                    decoration-muted="ged_state == 'archived'"
                    optional="show" />
                <field name="version_count" optional="hide" string="Versions" />
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Search: add GED filters                                      -->
    <!-- ============================================================ -->
    <record id="search_dms_file_ged" model="ir.ui.view">
        <field name="name">dms.file.search.inherit.isic_ged</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.search_dms_file" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="document_type_id" />
                <field name="reference" />
                <field name="partner_id" />
            </xpath>
            <xpath expr="//filter[@name='filter_user']" position="before">
                <filter name="filter_ged_draft" string="Brouillon" domain="[('ged_state','=','draft')]" />
                <filter name="filter_to_validate" string="À valider"
                    domain="[('ged_state','=','draft'),('document_type_id.validation_required','=',True)]" />
                <filter name="filter_ged_validated" string="Validés" domain="[('ged_state','=','validated')]" />
                <filter name="filter_ged_archived" string="Classés" domain="[('ged_state','=','archived')]" />
                <separator />
                <filter name="filter_this_year" string="Cette année"
                    domain="[('annee_academique_id.state','=','open')]" />
                <filter name="filter_fulltext_indexed" string="Indexés"
                    domain="[('fulltext_indexed','=',True)]" />
                <separator />
            </xpath>
            <xpath expr="//filter[@name='group_category']" position="after">
                <filter name="group_document_type" string="Type de document" context="{'group_by': 'document_type_id'}" />
                <filter name="group_ged_state" string="État GED" context="{'group_by': 'ged_state'}" />
                <filter name="group_annee" string="Année académique" context="{'group_by': 'annee_academique_id'}" />
                <filter name="group_date_document" string="Date du document" context="{'group_by': 'date_document:month'}" />
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Kanban: add GED state badge                                 -->
    <!-- ============================================================ -->
    <record id="view_dms_file_kanban_ged" model="ir.ui.view">
        <field name="name">dms.file.kanban.inherit.isic_ged</field>
        <field name="model">dms.file</field>
        <field name="inherit_id" ref="dms.view_dms_file_kanban" />
        <field name="arch" type="xml">
            <!-- Load ged_state field in kanban -->
            <xpath expr="//kanban/field[@name='name']" position="after">
                <field name="ged_state" />
                <field name="document_type_id" />
            </xpath>
            <!-- Add state badge after write_date in card -->
            <xpath expr="//div[hasclass('col-9')]/field[@name='write_date']" position="after">
                <span t-if="record.ged_state.raw_value"
                    t-attf-class="badge rounded-pill #{record.ged_state.raw_value == 'draft' ? 'text-bg-info' : record.ged_state.raw_value == 'validated' ? 'text-bg-success' : 'text-bg-secondary'}">
                    <t t-out="record.ged_state.value" />
                </span>
            </xpath>
        </field>
    </record>

    <!-- ============================================================ -->
    <!-- Menus                                                        -->
    <!-- ============================================================ -->
    <menuitem
        id="menu_ged_root"
        name="GED"
        sequence="15"
        web_icon="isic_ged,static/description/icon.png"
    />

    <record id="action_isic_ged_documents" model="ir.actions.act_window">
        <field name="name">Documents</field>
        <field name="res_model">dms.file</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="context">{'default_ged_state': 'draft'}</field>
    </record>

    <menuitem
        id="menu_isic_documents"
        name="Documents"
        parent="menu_ged_root"
        action="action_isic_ged_documents"
        sequence="10"
    />

    <!-- ============================================================ -->
    <!-- Server action: reindex all documents (admin)                 -->
    <!-- ============================================================ -->
    <record id="action_reindex_all_fulltext" model="ir.actions.server">
        <field name="name">Réindexer le contenu full-text</field>
        <field name="model_id" ref="dms.model_dms_file" />
        <field name="binding_model_id" ref="dms.model_dms_file" />
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="group_ids" eval="[(4, ref('isic_base.group_isic_direction'))]" />
        <field name="code">records.action_reindex_fulltext()</field>
    </record>

    <!-- ============================================================ -->
    <!-- Hide native DMS menus (users use ISIC GED instead)           -->
    <!-- ============================================================ -->
    <record id="dms.main_menu_dms" model="ir.ui.menu">
        <field name="active" eval="False" />
    </record>

    <!-- Hide "Migrer" action (technical, confusing for end users) -->
    <record id="dms.action_dms_attachment_migrate" model="ir.actions.server">
        <field name="binding_model_id" eval="False" />
    </record>
</odoo>
