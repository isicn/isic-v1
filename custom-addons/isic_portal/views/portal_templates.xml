<?xml version="1.0" encoding="UTF-8" ?>
<odoo>

    <!-- ============================================================ -->
    <!--  Card accueil /my : "Mes demandes"                           -->
    <!-- ============================================================ -->

    <template id="portal_my_home_demandes" name="Portal: Mes demandes"
              inherit_id="portal.portal_my_home" priority="45">
        <xpath expr="//div[hasclass('o_portal_docs')]" position="before">
            <t t-set="portal_client_category_enable" t-value="True"/>
        </xpath>
        <div id="portal_client_category" position="inside">
            <t t-call="portal.portal_docs_entry">
                <t t-set="title">Mes demandes</t>
                <t t-set="text">Demandes d'approbation</t>
                <t t-set="url" t-value="'/my/demandes'" />
                <t t-set="placeholder_count" t-value="'demande_count'" />
                <t t-set="config_card" t-value="True" />
            </t>
        </div>
    </template>

    <!-- ============================================================ -->
    <!--  Breadcrumbs                                                  -->
    <!-- ============================================================ -->

    <template id="portal_breadcrumbs_demandes" name="Demandes: Breadcrumbs"
              inherit_id="portal.portal_breadcrumbs" priority="45">
        <xpath expr="//ol[hasclass('o_portal_submenu')]" position="inside">
            <!-- Liste -->
            <li t-if="page_name == 'demandes'" class="breadcrumb-item active">
                Mes demandes
            </li>
            <!-- Detail -->
            <li t-if="page_name == 'demande_detail'" class="breadcrumb-item">
                <a href="/my/demandes">Mes demandes</a>
            </li>
            <li t-if="page_name == 'demande_detail'" class="breadcrumb-item active">
                <t t-out="demande.name" />
            </li>
            <!-- Nouveau -->
            <li t-if="page_name == 'demande_new'" class="breadcrumb-item">
                <a href="/my/demandes">Mes demandes</a>
            </li>
            <li t-if="page_name == 'demande_new'" class="breadcrumb-item active">
                Nouvelle demande
            </li>
        </xpath>
    </template>

    <!-- ============================================================ -->
    <!--  Liste : /my/demandes                                        -->
    <!-- ============================================================ -->

    <template id="portal_my_demandes" name="Mes demandes">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />

            <t t-call="portal.portal_searchbar">
                <t t-set="title">Mes demandes</t>
            </t>

            <div class="mb-3">
                <a href="/my/demandes/new" class="btn btn-primary">
                    <i class="fa fa-plus" title="Nouvelle demande" /> Nouvelle demande
                </a>
            </div>

            <t t-if="not demandes">
                <div class="alert alert-info" role="alert">
                    Aucune demande trouvee.
                </div>
            </t>

            <t t-if="demandes" t-call="portal.portal_table">
                <thead>
                    <tr>
                        <th>Reference</th>
                        <th>Categorie</th>
                        <th>Date</th>
                        <th>Priorite</th>
                        <th class="text-center">Etat</th>
                    </tr>
                </thead>
                <tbody>
                    <t t-foreach="demandes" t-as="dem">
                        <tr>
                            <td>
                                <a t-attf-href="/my/demandes/#{dem.id}">
                                    <t t-out="dem.name" />
                                </a>
                            </td>
                            <td>
                                <t t-if="dem.categorie_id.icon">
                                    <i t-att-class="dem.categorie_id.icon"
                                       t-att-title="dem.categorie_id.name" />
                                </t>
                                <t t-out="dem.categorie_id.name" />
                            </td>
                            <td>
                                <span t-out="dem.create_date"
                                      t-options="{'widget': 'date'}" />
                            </td>
                            <td>
                                <t t-if="dem.priorite == '1'">
                                    <span class="badge bg-warning text-dark">Urgente</span>
                                </t>
                                <t t-elif="dem.priorite == '2'">
                                    <span class="badge bg-danger">Tres urgente</span>
                                </t>
                                <t t-else="">
                                    <span class="text-muted">Normale</span>
                                </t>
                            </td>
                            <td class="text-center">
                                <span t-attf-class="badge #{
                                    'bg-secondary' if dem.state == 'draft' else
                                    'bg-info' if dem.state == 'submitted' else
                                    'bg-success' if dem.state == 'approved' else
                                    'bg-danger' if dem.state == 'rejected' else
                                    'bg-dark'}">
                                    <t t-out="dict(dem._fields['state'].selection).get(dem.state, dem.state)" />
                                </span>
                            </td>
                        </tr>
                    </t>
                </tbody>
            </t>
        </t>
    </template>

    <!-- ============================================================ -->
    <!--  Detail : /my/demandes/<id>                                  -->
    <!-- ============================================================ -->

    <template id="portal_my_demande_detail" name="Detail demande">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />

            <div class="card mb-4">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h4 class="mb-0">
                        <t t-out="demande.name" />
                    </h4>
                    <span t-attf-class="badge fs-6 #{
                        'bg-secondary' if demande.state == 'draft' else
                        'bg-info' if demande.state == 'submitted' else
                        'bg-success' if demande.state == 'approved' else
                        'bg-danger' if demande.state == 'rejected' else
                        'bg-dark'}">
                        <t t-out="dict(demande._fields['state'].selection).get(demande.state, demande.state)" />
                    </span>
                </div>
                <div class="card-body">
                    <!-- Alert si rejete -->
                    <t t-if="demande.state == 'rejected' and demande.motif_refus">
                        <div class="alert alert-danger">
                            <strong>Motif du refus :</strong>
                            <t t-out="demande.motif_refus" />
                        </div>
                    </t>

                    <div class="row mb-3">
                        <!-- Informations -->
                        <div class="col-md-6">
                            <table class="table table-sm">
                                <tr>
                                    <td class="fw-bold">Categorie</td>
                                    <td>
                                        <t t-if="demande.categorie_id.icon">
                                            <i t-att-class="demande.categorie_id.icon"
                                               t-att-title="demande.categorie_id.name" />
                                        </t>
                                        <t t-out="demande.categorie_id.name" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Date de demande</td>
                                    <td>
                                        <span t-out="demande.date_demande"
                                              t-options="{'widget': 'date'}" />
                                    </td>
                                </tr>
                                <tr t-if="demande.date_debut">
                                    <td class="fw-bold">Date de debut</td>
                                    <td>
                                        <span t-out="demande.date_debut"
                                              t-options="{'widget': 'date'}" />
                                    </td>
                                </tr>
                                <tr t-if="demande.date_fin">
                                    <td class="fw-bold">Date de fin</td>
                                    <td>
                                        <span t-out="demande.date_fin"
                                              t-options="{'widget': 'date'}" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Priorite</td>
                                    <td>
                                        <t t-out="dict(demande._fields['priorite'].selection).get(demande.priorite, demande.priorite)" />
                                    </td>
                                </tr>
                            </table>
                        </div>
                        <!-- Decision -->
                        <div class="col-md-6" t-if="demande.date_decision">
                            <table class="table table-sm">
                                <tr>
                                    <td class="fw-bold">Date de decision</td>
                                    <td>
                                        <span t-out="demande.date_decision"
                                              t-options="{'widget': 'datetime', 'format': 'dd/MM/yyyy HH:mm'}" />
                                    </td>
                                </tr>
                            </table>
                        </div>
                    </div>

                    <!-- Motif -->
                    <h6 class="fw-bold">Motif</h6>
                    <p class="mb-3" style="white-space: pre-wrap;"><t t-out="demande.motif" /></p>

                    <!-- Observations -->
                    <t t-if="demande.observations">
                        <h6 class="fw-bold">Observations</h6>
                        <p class="mb-3" style="white-space: pre-wrap;"><t t-out="demande.observations" /></p>
                    </t>

                    <!-- Piece jointe -->
                    <t t-if="demande.piece_jointe">
                        <h6 class="fw-bold">Piece jointe</h6>
                        <a t-attf-href="/web/content?model=isic.approbation.demande&amp;id=#{demande.id}&amp;field=piece_jointe&amp;filename_field=nom_fichier&amp;download=true"
                           class="btn btn-sm btn-outline-primary mb-3">
                            <i class="fa fa-download" title="Telecharger" />
                            <t t-out="demande.nom_fichier or 'Telecharger'" />
                        </a>
                    </t>

                    <!-- Circuit d'approbation -->
                    <t t-if="demande.review_ids">
                        <h6 class="fw-bold mt-3">Circuit d'approbation</h6>
                        <table class="table table-sm">
                            <thead>
                                <tr>
                                    <th>Approbateur</th>
                                    <th class="text-center">Statut</th>
                                    <th>Commentaire</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="demande.review_ids" t-as="review">
                                    <tr>
                                        <td>
                                            <t t-out="review.reviewer_ids[:1].name" />
                                        </td>
                                        <td class="text-center">
                                            <span t-if="review.status == 'pending'"
                                                  class="badge bg-warning text-dark">En attente</span>
                                            <span t-elif="review.status == 'approved'"
                                                  class="badge bg-success">Approuve</span>
                                            <span t-elif="review.status == 'rejected'"
                                                  class="badge bg-danger">Refuse</span>
                                            <span t-else=""
                                                  class="badge bg-secondary">
                                                <t t-out="review.status" />
                                            </span>
                                        </td>
                                        <td>
                                            <t t-out="review.comment or ''" />
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </t>
                </div>
            </div>

            <!-- Chatter portal -->
            <div class="mt-4">
                <h5>Historique</h5>
                <t t-call="portal.message_thread">
                    <t t-set="object" t-value="demande" />
                </t>
            </div>

            <div class="mt-3 mb-4">
                <a href="/my/demandes" class="btn btn-outline-secondary">
                    <i class="fa fa-arrow-left" title="Retour" /> Retour aux demandes
                </a>
            </div>
        </t>
    </template>

    <!-- ============================================================ -->
    <!--  Formulaire : /my/demandes/new                               -->
    <!-- ============================================================ -->

    <template id="portal_my_demande_new" name="Nouvelle demande">
        <t t-call="portal.portal_layout">
            <t t-set="breadcrumbs_searchbar" t-value="True" />

            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Nouvelle demande</h5>
                </div>
                <div class="card-body">
                    <!-- Erreurs -->
                    <t t-if="error_message">
                        <div class="alert alert-danger">
                            <t t-foreach="error_message" t-as="msg">
                                <div><t t-out="msg" /></div>
                            </t>
                        </div>
                    </t>

                    <form action="/my/demandes/submit" method="POST"
                          enctype="multipart/form-data">
                        <input type="hidden" name="csrf_token"
                               t-att-value="request.csrf_token()" />

                        <!-- Categorie -->
                        <div class="mb-3">
                            <label for="categorie_id" class="form-label fw-bold">
                                Categorie *
                            </label>
                            <select name="categorie_id" id="categorie_id"
                                    required="required"
                                    t-attf-class="form-select #{'is-invalid' if error.get('categorie_id') else ''}">
                                <option value="">-- Selectionnez --</option>
                                <t t-foreach="categories" t-as="cat">
                                    <option t-att-value="cat.id"
                                            t-att-selected="str(cat.id) == str(categorie_id) if categorie_id else None">
                                        <t t-out="cat.name" />
                                    </option>
                                </t>
                            </select>
                        </div>

                        <!-- Motif -->
                        <div class="mb-3">
                            <label for="motif" class="form-label fw-bold">
                                Motif *
                            </label>
                            <textarea name="motif" id="motif" rows="4"
                                      required="required"
                                      placeholder="Decrivez votre demande..."
                                      t-attf-class="form-control #{'is-invalid' if error.get('motif') else ''}"><t t-out="motif if motif else ''" /></textarea>
                        </div>

                        <!-- Dates -->
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="date_debut" class="form-label">
                                    Date de debut
                                </label>
                                <input type="date" name="date_debut" id="date_debut"
                                       class="form-control"
                                       t-att-value="date_debut if date_debut else ''" />
                            </div>
                            <div class="col-md-6">
                                <label for="date_fin" class="form-label">
                                    Date de fin
                                </label>
                                <input type="date" name="date_fin" id="date_fin"
                                       class="form-control"
                                       t-att-value="date_fin if date_fin else ''" />
                            </div>
                        </div>

                        <!-- Priorite -->
                        <div class="mb-3">
                            <label for="priorite" class="form-label">
                                Priorite
                            </label>
                            <select name="priorite" id="priorite" class="form-select">
                                <option value="0"
                                        t-att-selected="not priorite or priorite == '0'">
                                    Normale
                                </option>
                                <option value="1"
                                        t-att-selected="priorite == '1' if priorite else None">
                                    Urgente
                                </option>
                                <option value="2"
                                        t-att-selected="priorite == '2' if priorite else None">
                                    Tres urgente
                                </option>
                            </select>
                        </div>

                        <!-- Observations -->
                        <div class="mb-3">
                            <label for="observations" class="form-label">
                                Observations
                            </label>
                            <textarea name="observations" id="observations" rows="2"
                                      class="form-control"
                                      placeholder="Informations complementaires..."><t t-out="observations if observations else ''" /></textarea>
                        </div>

                        <!-- Piece jointe -->
                        <div class="mb-3">
                            <label for="piece_jointe" class="form-label">
                                Piece jointe
                            </label>
                            <input type="file" name="piece_jointe" id="piece_jointe"
                                   class="form-control" />
                        </div>

                        <!-- Boutons -->
                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-paper-plane" title="Soumettre" /> Soumettre
                            </button>
                            <a href="/my/demandes" class="btn btn-outline-secondary">
                                Annuler
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </t>
    </template>

</odoo>
