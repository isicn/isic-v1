<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data noupdate="0">

        <!-- ============================================ -->
        <!-- ir.rule : portal users see own demandes      -->
        <!-- ============================================ -->
        <record id="rule_demande_portal" model="ir.rule">
            <field name="name">Demandes : portail voit ses propres demandes</field>
            <field name="model_id" ref="isic_approbation.model_isic_approbation_demande" />
            <field name="groups" eval="[(4, ref('base.group_portal'))]" />
            <field name="domain_force">[('demandeur_id', '=', user.id)]</field>
        </record>

        <!-- ============================================ -->
        <!-- ir.rule : portal users read all categories   -->
        <!-- ============================================ -->
        <record id="rule_categorie_portal" model="ir.rule">
            <field name="name">Categories : portail lecture</field>
            <field name="model_id" ref="isic_approbation.model_isic_approbation_categorie" />
            <field name="groups" eval="[(4, ref('base.group_portal'))]" />
            <field name="domain_force">[
                '|',
                ('groupe_demandeur_ids', '=', False),
                ('groupe_demandeur_ids', 'in', user.group_ids.ids),
            ]</field>
        </record>

        <!-- ============================================ -->
        <!-- ir.rule : portal users read approbateurs     -->
        <!-- ============================================ -->
        <record id="rule_approbateur_portal" model="ir.rule">
            <field name="name">Approbateurs : portail lecture</field>
            <field name="model_id" ref="isic_approbation.model_isic_approbation_approbateur" />
            <field name="groups" eval="[(4, ref('base.group_portal'))]" />
            <field name="domain_force">[(1, '=', 1)]</field>
        </record>

    </data>
</odoo>
